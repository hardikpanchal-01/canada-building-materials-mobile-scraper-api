# =============================================================================
# Scraped Order API - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
prompts/
# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# Google / Firebase service-account credentials — provide out-of-band (like .env)
src/config/*firebase-adminsdk*.json
*serviceaccount*.json
*-adminsdk-*.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
.claude/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# Local backups (e.g. revoked Firebase key kept for rollback)
*.revoked-bak

/docs